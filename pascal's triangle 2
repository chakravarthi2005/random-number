class Solution:
    def getRow(self, rowIndex: int) -> List[int]:
        row = [1] * (rowIndex + 1)  # Start with all 1s
        for i in range(1, rowIndex):  # Build up to target row
            for j in range(i, 0, -1): # Right-to-left update
                row[j] += row[j-1]    # Pascal's rule: C(n,k) = C(n-1,k-1) + C(n-1,k)
        return row
